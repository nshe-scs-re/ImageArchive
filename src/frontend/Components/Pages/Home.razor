@page "/"
@attribute [StreamRendering]
@rendermode InteractiveServer
@inject HttpService HttpService
@inject IJSRuntime JS

<PageTitle>Home</PageTitle>

<style>
    /* Remove the green outline on focus */
    .form-control:focus, .form-select:focus, .btn-outline-secondary:focus {
        outline: none; /* Remove default browser outline */
        box-shadow: 0 0 5px 1px #888888; /* Optional: Add a custom shadow */
        border-color: #666666; /* Optional: Match border color for consistency */
    }

    /* Light mode default styles */
    body {
        background-color: #ffffff;
        color: #000000;
    }

    .container, .bg-body-tertiary, .form {
        background-color: #f8f9fa; /* Light grey for containers */
    }

    /* Dark mode styles */
    .dark-mode {
        background-color: #333333; /* Dark grey background */
        color: #ffffff; /* White text color */
    }

        .dark-mode .container,
        .dark-mode .bg-body-tertiary,
        .dark-mode .form {
            background-color: #444444; /* Darker grey for containers */
        }

        .dark-mode .form-control,
        .dark-mode .form-select,
        .dark-mode .btn-outline-secondary,
        .dark-mode .pagination .page-link,
        .dark-mode .card,
        .dark-mode .border {
            background-color: #555555; /* Grey for form controls */
            color: #ffffff;
            border-color: #666666;
        }

        .dark-mode h1, .dark-mode p, .dark-mode label {
            color: #ffffff;
        }

        .dark-mode .lead {
            color: #cccccc;
        }
</style>


<!-- Dark mode toggle button at the top -->
<div class="text-center py-2">
    <button type="button" class="btn btn-outline-secondary" @onclick="ToggleDarkMode">Toggle Dark Mode</button>
</div>

<div class="my-3 py-3 text-center rounded">
    <div class="row">
        <div class="col-lg-6 col-md-8 mx-auto">
            <h1 class="fw-light py-2">Image Repository Search</h1>
            <p class="lead">Execute a query against the image repository by using the tool below.</p>
        </div>
    </div>
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10 p-3">
            <EditForm Model="@imageQuery" OnValidSubmit="FormSubmit" FormName="MyFormName" class="form border rounded p-3">
                <div class="row py-2">
                    <label for="StartDate" class="col col-form-label">Query start date:</label>
                    <div class="col">
                        <InputDate id="StartDate" @bind-Value="imageQuery.StartDateTime" Type="InputDateType.Date" class="form-control" />
                    </div>
                </div>
                <div class="row py-2">
                    <label for="EndDate" class="col col-form-label">Query end date:</label>
                    <div class="col">
                        <InputDate id="EndDate" @bind-Value="imageQuery.EndDateTime" Type="InputDateType.Date" class="form-control" />
                    </div>
                </div>
                <div class="row py-2">
                    <label for="StartTime" class="col col-form-label">Query start time:</label>
                    <div class="col">
                        <InputDate id="StartTime" @bind-Value="imageQuery.StartTimeOnly" Type="InputDateType.Time" class="form-control" />
                    </div>
                </div>
                <div class="row py-2">
                    <label for="EndTime" class="col col-form-label">Query end time:</label>
                    <div class="col">
                        <InputDate id="EndTime" @bind-Value="imageQuery.EndTimeOnly" Type="InputDateType.Time" class="form-control" />
                    </div>
                </div>
                <div class="row py-2">
                    <label for="Site" class="col col-form-label">Site Name:</label>
                    <div class="col">
                        <InputSelect @bind-Value="imageQuery.Site" id="Site" class="form-select">
                            <option value="">Sheep</option>
                            <option value="">Site 2</option>
                            <option value="">Site 3</option>
                            <option value="">Site 4</option>
                        </InputSelect>
                    </div>
                </div>
                <div class="row py-2">
                    <label for="CameraNumber" class="col col-form-label">Camera Number:</label>
                    <div class="col">
                        <InputSelect @bind-Value="imageQuery.CameraNumber" id="CameraNumber" class="form-select">
                            <option value="1">Camera 1</option>
                            <option value="2">Camera 2</option>
                            <option value="3">Camera 3</option>
                        </InputSelect>
                    </div>
                </div>
                <div class="row py-2">
                    <label for="CameraPosition" class="col col-form-label">Camera Position:</label>
                    <div class="col">
                        <InputSelect @bind-Value="imageQuery.CameraPosition" id="CameraPosition" class="form-select">
                            <option value="1">Position 1</option>
                            <option value="2">Position 2</option>
                            <option value="3">Position 3</option>
                        </InputSelect>
                    </div>
                </div>
                <div class="text-end py-2">
                    <button type="submit" class="btn btn-outline-secondary">Search</button>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@if (loading)
{
    <div class="my-3 py-3 album rounded">
        <div class="container">
            <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-3">
                @for (int i = 0; i < pageSize; i++)
                {
                    <div class="col">
                        <div class="card shadow-sm">
                            <img src="/placeholder.jpg" class="card-img-top" />
                            <div class="card-body">
                                <p class="card-text">Information about image</p>
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="btn-group">
                                        <button type="button" class="btn btn-sm btn-outline-secondary">View</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}
else
{
    <div class="my-3 py-3 album rounded">
        <div class="container">
            <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-3">
                @foreach (var image in images)
                {
                    <div class="col">
                        <div class="card shadow-sm">
                            <img src="/api/images/@image.Id" class="card-img-top" />
                            <div class="card-body">
                                <p class="card-text">Information about image</p>
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="btn-group">
                                        <button type="button" class="btn btn-sm btn-outline-secondary">View</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <nav aria-label="Pagination">
        <ul class="pagination justify-content-center">
            <li class="page-item @(pageIndex == 0 ? "disabled" : "")">
                <button class="page-link" @onclick="PreviousPage">Previous</button>
            </li>
            <li class="page-item">
                <span class="page-link">@(pageIndex + 1)</span>
            </li>
            <li class="page-item">
                <button class="page-link" @onclick="NextPage">Next</button>
            </li>
        </ul>
    </nav>
}

<script>
    function toggleDarkMode() {
        document.body.classList.toggle('dark-mode'); // Toggle the dark mode class on the body
    }
</script>

@code
{
    ImageQuery imageQuery = new ImageQuery()
        {
            StartDateTime = new DateTime(2019, 6, 1),
            EndDateTime = DateTime.Now.Date
        };

    public bool loading = false;
    private List<Image> images = new();
    private int pageIndex = 0;
    private int pageSize = 9;

    private async Task FormSubmit()
    {
        imageQuery.StartDateTime = new DateTime(DateOnly.FromDateTime(imageQuery.StartDateTime), imageQuery.StartTimeOnly);
        imageQuery.EndDateTime = new DateTime(DateOnly.FromDateTime(imageQuery.EndDateTime), imageQuery.EndTimeOnly);

        loading = true;

        var response = await HttpService.GetImages(imageQuery.StartDateTime, imageQuery.EndDateTime, pageIndex, pageSize);

        if (response is not null)
        {
            if (response.IsSuccessStatusCode)
            {
                images = await response.Content.ReadFromJsonAsync<List<Image>>();
            }
        }

        loading = false;
    }

    private async Task NextPage()
    {
        pageIndex++;
        await FormSubmit();
    }

    private async Task PreviousPage()
    {
        if (pageIndex > 0)
        {
            pageIndex--;
            await FormSubmit();
        }
    }

    private async Task ToggleDarkMode()
    {
        await JS.InvokeVoidAsync("toggleDarkMode");
    }
}
